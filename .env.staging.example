# Staging environment — local Docker Desktop
# Copy to .env.staging and fill in values.

# Database
DATABASE_URL=postgresql://malarkrets:malarkrets_dev@postgres:5432/malarkrets
POSTGRES_PASSWORD=malarkrets_dev

# NextAuth
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Google Maps
# NOTE: NEXT_PUBLIC_* vars are baked into the client bundle at `next build`.
# Only needed if you build locally (bun run dev / docker build locally).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# SMTP (optional for staging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@malarkrets.se

# Image tags — leave unset to track :latest / :migrate-latest from master.
# APP_TAG=
# MIGRATE_TAG=

# Caddy reverse proxy
DOMAIN=localhost
LETSENCRYPT_EMAIL=
