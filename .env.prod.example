# Production environment — VPS
# Copy to .env.prod and fill in values. NEVER commit .env.prod.

# Database
DATABASE_URL=postgresql://malarkrets:CHANGE_ME@postgres:5432/malarkrets
POSTGRES_PASSWORD=CHANGE_ME

# NextAuth
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
AUTH_URL=https://malarkrets.se

# Google Maps
# NOTE: NEXT_PUBLIC_* vars are baked into the client bundle at `next build`.
# In CI, this is injected as a Docker build-arg from the GitHub secret.
# Not needed in prod .env — the value is already in the image.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Email (Resend — https://resend.com)
# RESEND_API_KEY: sätts antingen direkt i .env.prod på VPS eller som GitHub Secret.
RESEND_API_KEY=
EMAIL_FROM=noreply@malarkrets.se

# Top-of-page banner. Tomt / unset = dölj bannern.
# Används just nu för att tydliggöra att sidan är under utveckling.
SITE_BANNER_TEXT=

# Image tags — leave unset to track :latest / :migrate-latest from master.
# Pin to a semver tag for prod (e.g. APP_TAG=1.2.3, MIGRATE_TAG=migrate-1.2.3).
# App and migrate MUST always match — see RELEASE.md.
# APP_TAG=
# MIGRATE_TAG=

# Caddy reverse proxy
# Caddy fetches a Let's Encrypt cert automatically on first request.
DOMAIN=malarkrets.se
LETSENCRYPT_EMAIL=hakan.froling@anome.se
