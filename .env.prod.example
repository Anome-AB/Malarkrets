# Database
DATABASE_URL=postgresql://malarkrets:CHANGE_ME@postgres:5432/malarkrets
POSTGRES_PASSWORD=CHANGE_ME

# NextAuth
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# Google Maps
# NOTE: NEXT_PUBLIC_* vars are baked into the client bundle at `next build`.
# In CI, this is injected as a Docker build-arg from the
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY GitHub secret and ends up in the image.
# Only set this here if you build locally (bun run dev / docker build locally).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# SMTP (for nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@malarkrets.se

# Caddy reverse proxy
# DOMAIN: leave as `localhost` for local compose testing (HTTP, no cert).
#         Set to the real hostname in prod (e.g. malarkrets.se) and Caddy
#         will fetch a Let's Encrypt cert automatically on first request.
# LETSENCRYPT_EMAIL: required when DOMAIN is a real hostname.
DOMAIN=localhost
LETSENCRYPT_EMAIL=admin@example.com
